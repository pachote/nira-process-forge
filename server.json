{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pachote/nira-process-forge",
  "title": "NIRA Process Forge MCP",
  "description": "Process management for Claude \u2014 launch, monitor, and control background system processes",
  "repository": {
    "url": "https://github.com/pachote/nira-process-forge",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "nira-process-forge",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PROC_FORGE_LOG_DIR",
          "description": "Directory for process logs (default: ~/proc_forge_logs)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}